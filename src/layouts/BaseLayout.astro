---
import Alert from "@/components/Alert.astro";
import Footer from "@/components/Footer.astro";
import MainHead from "@/components/MainHead.astro";
import Navbar from "@/components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "A.R.M. Corporations del Perú | Proveedores del Estado",
  description = "A.R.M. Corporations del Perú E.I.R.L. — Empresa multisectorial proveedora del Estado peruano. Comercialización mayorista y minorista, manufactura y logística comercial.",
} = Astro.props;

const alertMessage = "Explora nuestro catálogo completo de productos y servicios";
---

<!doctype html>
<html lang="es">
  <head>
    <MainHead title={title} description={description} />
  </head>
  <body>
    <Alert message={alertMessage} />
    <Navbar />
    <main>
      <slot />
    </main>
    <div class="Footer-bg">
      <Footer />
    </div>
  </body>
</html>

<style>
  body {
    background-color: var(--bg-color);
  }
  main {
    margin: 0;
    width: 100%;
  }
  .Footer-bg {
    background-color: var(--color-secondary-light);
  }
</style>
